---
const { class: className, ...rest } = Astro.props
---

<div class="m-auto flex w-full p-4">
    <div class="grid-columns-2-1 grid gap-x-4">
        <slot />
    </div>
</div>
<style>
    @media screen and (width >= 768px) {
        .grid-columns-2-1 {
            grid-template-columns: 2fr 1fr;
        }
    }
</style>
