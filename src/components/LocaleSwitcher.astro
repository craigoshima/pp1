---
import { localizePath } from "../utils/i18n.ts"

const currentPath = Astro.url.pathname
const enPath = localizePath(currentPath, "en")
const esPath = localizePath(currentPath, "es")
const frPath = localizePath(currentPath, "fr")
---

<!-- <div
    class="bg-opacity-20 bg-powderblue-100 inline-block rounded-full px-4 py-1 text-right text-sm text-gray-400"
>
 -->
<div class="inline-block px-4 text-sm text-gray-400">
    <span class="font-bold text-gray-800">English</span> |
    <a href={esPath} class="">Español</a> |
    <a href={frPath} class="">Français</a>
</div>
