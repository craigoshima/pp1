---
import Layout from "../layouts/Layout.astro"
import ForumEventCard from "../components/ForumEventCard.astro"
import SectionColumned from "../components/SectionColumned.astro"
import LocaleSwitcher from "../components/LocaleSwitcher.astro"
---

<Layout>
    <header class="hero">
        <div class="mx-auto max-w-[1024px]">
            <SectionColumned>
                <div>
                    <img
                        src="/images/pps-logo.svg"
                        alt="Professionals Platform Series"
                        style="height:168px"
                    />
                    <p class="p-4 text-xl italic">
                        A forum convening professionals and A.A. across the
                        United States and Canada to strengthen support for
                        individuals with Alcohol Use Disorder. The platform will
                        feature a series of conversations across sectors,
                        beginning in July 2026.
                    </p>
                </div>
                <div class="p-3 text-right">
                    <LocaleSwitcher />
                </div>
            </SectionColumned>
        </div>
    </header>
    <main class="mx-auto max-w-[1024px]">
        <SectionColumned>
            <div>
                <div class="relative grid gap-4 sm:grid-cols-2">
                    <ForumEventCard>
                        <div slot="dateinfo">
                            <p>Thursday</p>
                            <p class="text-xl">
                                <strong>23 July 2026</strong>
                            </p>
                        </div>
                        <main class="px-2 py-4">
                            <h3 class="text-2xl">
                                <strong
                                    ><span href="session">Dawn Klug</span><br
                                    /><small>M.S., LCMHC, CEAP</small></strong
                                >
                            </h3>
                            <p>
                                President and Chief Operating Officer<br />
                                Employee Assistance Network
                            </p>

                            <p class="mt-4">
                                Class A Trustee<br />Alcoholics Anonymous
                            </p>
                        </main>
                    </ForumEventCard>
                    <ForumEventCard>
                        <div slot="dateinfo">
                            <p>Thursday</p>
                            <p class="text-xl">
                                <strong>22 October 2026</strong>
                            </p>
                        </div>
                        <main class="px-2 py-4">
                            <h3 class="text-2xl">
                                <strong> Chief Judge<br /> Kerry Meyer</strong>
                            </h3>
                            <p>Minneapolis</p>
                            <p class="mt-4">
                                Class A Trustee<br /> Alcoholics Anonymous
                            </p>
                        </main>
                    </ForumEventCard>
                </div>
                <div class="mt-4">
                    <h2 id="upcoming" class="text-2xl font-bold italic">
                        Upcoming in 2027
                    </h2>
                </div>
                <div class="mt-4 grid gap-4 sm:grid-cols-2">
                    <div class="bg-zest-200 rounded-2xl px-4 py-2 text-center">
                        <p class="text-lg font-bold">Veronica Ramirez</p>
                        <p>Chief U.S. Probation Officer</p>
                        <p class="pt-4">
                            Class A Trustee<br />Alcoholics Anonymous
                        </p>
                    </div>
                    <div class="bg-zest-200 rounded-2xl px-4 py-2 text-center">
                        <p class="text-lg font-bold">Molly Oliver</p>
                        <p>
                            Chief Operating Officer<br />Catholic Charities of
                            Buffalo
                        </p>
                        <p class="pt-4">
                            Class A Trustee<br />Alcoholics Anonymous
                        </p>
                    </div>
                </div>
            </div>
            <div class="flex flex-col gap-4 rounded-2xl bg-gray-100 px-4 pt-4">
                <div class="flex gap-2">
                    <!-- <Clock class="w-8" /> -->
                    <div>
                        <h3 class="text-lg font-bold">Online Forum</h3>
                        <div class="mt-1">
                            <p>7:00 – 8:30 PM ET</p>
                            <p>6:00 – 7:30 PM CT</p>
                            <p>4:00 – 5:30 PM PT</p>
                        </div>
                        <p class="mt-4">
                            Spanish and French interpretation available.
                        </p>
                        <p class="mt-2">
                            Additional information, including virtual access
                            details, forthcoming.
                        </p>
                    </div>
                </div>

                <div class="grow">
                    <h3 class="text-lg font-bold">Links</h3>
                    <p>
                        <a
                            href="https://www.aa.org/Cooperation-with-the-Professional-Community"
                            target="_blank"
                            class="text-cyan-700"
                            >Cooperation with the Professional Community (CPC)
                        </a>
                    </p>
                    <p class="mt-4">
                        <a
                            href="https://www.aa.org/public-information-committees"
                            target="_blank">Public Information Committees</a
                        >
                    </p>
                </div>

                <div class="pb-4">
                    <h3 class="text-lg font-bold">About</h3>
                    <p>
                        <a href="about" class="text-cyan-700">About Us</a> |
                        <a href="mailto:info@professionalsplatform.org"
                            >Contact Us</a
                        >
                    </p>
                </div>
            </div>
        </SectionColumned>
    </main>

    <style>
        .hero {
            background:
                linear-gradient(
                    92deg,
                    #b9dfe9 30%,
                    rgba(153, 211, 224, 0.75) 60%,
                    rgba(8, 81, 113, 0.3) 94.45%
                ),
                url("/images/mono-chairs-1600.jpg") lightgray 50% / cover
                    no-repeat;
        }

        #upcoming {
            position: relative;
            background-color: var(--color-zest-100);
            display: inline-flex;
            padding: 16px;
            padding-right: 8px;
            border-radius: 0.25em 0 0 0.25em;
        }
        #upcoming:after {
            position: absolute;
            content: "";
            top: 50%;
            right: -24px;
            z-index: -1;
            border-color: var(--color-zest-100);
            border-width: 0 45px 45px 0;
            transform: translateY(-50%) rotate(-45deg);
        }

        /* main {
        background: var(--color-powderblue-100);
        display: flex;
        flex-direction: column;
    } */
    </style>
</Layout>
