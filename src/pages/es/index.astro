---
import Layout from "../../layouts/Layout.astro"
import ForumEventCard from "../../components/ForumEventCard.astro"
import SectionColumned from "../../components/SectionColumned.astro"
import LocaleSwitcher from "../../components/es/LocaleSwitcher.astro"
---

<Layout>
    <header class="hero">
        <div class="mx-auto max-w-[1024px]">
            <SectionColumned>
                <div>
                    <img
                        src="/images/pps-logo.svg"
                        alt="Serie de plataformas para profesionales"
                        style="height:168px"
                    />
                    <div class="px-4 text-lg font-bold">
                        Serie de plataformas para profesionales
                    </div>
                    <p class="p-4 pt-2 text-xl italic">
                        Un foro intersectorial que reúne a profesionales y
                        miembros de Alcohólicos Anónimos de todo Estados Unidos
                        y Canadá para fortalecer el apoyo a las personas con
                        trastorno por consumo de alcohol. La plataforma ofrecerá
                        una serie de conversaciones que comenzarán en julio de
                        2026.
                    </p>
                </div>
                <div class="p-3 text-right">
                    <LocaleSwitcher />
                </div>
            </SectionColumned>
        </div>
    </header>
    <main class="mx-auto max-w-[1024px]">
        <SectionColumned>
            <div>
                <div class="relative grid gap-4 sm:grid-cols-2">
                    <ForumEventCard>
                        <div slot="dateinfo">
                            <p>Jueves</p>
                            <p class="text-xl">
                                <strong>23 de julio de 2026</strong>
                            </p>
                        </div>
                        <main class="px-2 py-4">
                            <h3 class="text-2xl">
                                <strong
                                    >Dawn Klug<br /><small
                                        >M.S., LCMHC, CEAP</small
                                    ></strong
                                >
                            </h3>
                            <p>
                                Presidenta y Directora de Operaciones de la Red
                                de Asistencia al Empleado
                            </p>

                            <p class="mt-4">
                                Miembro del consejo directivo de clase A de
                                Alcohólicos Anónimos
                            </p>
                        </main>
                    </ForumEventCard>
                    <ForumEventCard>
                        <div slot="dateinfo">
                            <p>Jueves</p>
                            <p class="text-xl">
                                <strong>22 de octubre de 2026</strong>
                            </p>
                        </div>
                        <main class="px-2 py-4">
                            <h3 class="text-2xl">
                                <strong> Chief Judge<br /> Kerry Meyer</strong>
                            </h3>
                            <p>Minneapolis</p>
                            <p class="mt-4">
                                Miembro del consejo directivo de clase A de
                                Alcohólicos Anónimos
                            </p>
                        </main>
                    </ForumEventCard>
                </div>
                <div class="mt-4">
                    <h2 id="upcoming" class="text-2xl font-bold italic">
                        Próximamente en 2027
                    </h2>
                </div>
                <div class="mt-4 grid gap-4 sm:grid-cols-2">
                    <div class="bg-zest-200 rounded-2xl px-4 py-2 text-center">
                        <p class="text-lg font-bold">Veronica Ramirez</p>
                        <p>
                            Jefe del Servicio de Libertad Condicional de los
                            Estados Unidos
                        </p>
                        <p class="pt-4">
                            Miembro del consejo directivo de clase A de
                            Alcohólicos Anónimos
                        </p>
                    </div>
                    <div class="bg-zest-200 rounded-2xl px-4 py-2 text-center">
                        <p class="text-lg font-bold">Molly Oliver</p>
                        <p>
                            Directora de Operaciones, Caridades Católicas de
                            Buffalo
                        </p>
                        <p class="pt-4">
                            Miembro del consejo directivo de clase A de
                            Alcohólicos Anónimos
                        </p>
                    </div>
                </div>
            </div>
            <div class="flex flex-col gap-4 rounded-2xl bg-gray-100 px-4 pt-4">
                <div class="flex gap-2">
                    <!-- <Clock class="w-8" /> -->
                    <div>
                        <h3 class="text-lg font-bold">Foros en línea</h3>
                        <div class="mt-1">
                            <p>19:00–20:30 (hora del este)</p>
                            <p>18:00–19:30 (hora del central)</p>
                            <p>16:00–17:30 (hora del pacifico)</p>
                        </div>
                        <p class="mt-4">
                            Servicio de interpretación disponible en español y
                            francés.
                        </p>
                        <p class="mt-2">
                            Próximamente se facilitará información adicional,
                            incluidos los detalles de acceso virtual.
                        </p>
                    </div>
                </div>

                <div class="grow">
                    <h3 class="text-lg font-bold">Enlaces</h3>
                    <p>
                        <a
                            href="https://www.aa.org/es/Cooperation-with-the-Professional-Community"
                            target="_blank"
                            class="text-cyan-700"
                            >Cooperación con la Comunidad Profesional (CCP)
                        </a>
                    </p>
                    <p class="mt-4">
                        <a
                            href="https://www.aa.org/es/public-information-committees"
                            target="_blank"
                            class="text-cyan-700"
                            >Comités de Información Pública</a
                        >
                    </p>
                </div>

                <div class="pb-4">
                    <h3 class="text-lg font-bold">Sobre nosotros</h3>
                    <p>
                        <a href="about" class="text-cyan-700">Sobre nosotros</a> |
                        <a href="mailto:info@professionalsplatform.org"
                            >Contáctanos</a
                        >
                    </p>
                </div>
            </div>
        </SectionColumned>
    </main>

    <style>
        .hero {
            background:
                linear-gradient(
                    92deg,
                    #b9dfe9 30%,
                    rgba(153, 211, 224, 0.75) 60%,
                    rgba(8, 81, 113, 0.3) 94.45%
                ),
                url("/images/mono-chairs-1600.jpg") lightgray 50% / cover
                    no-repeat;
        }

        #upcoming {
            position: relative;
            background-color: var(--color-zest-100);
            display: inline-flex;
            padding: 16px;
            padding-right: 8px;
            border-radius: 0.25em 0 0 0.25em;
        }
        #upcoming:after {
            position: absolute;
            content: "";
            top: 50%;
            right: -24px;
            z-index: -1;
            border-color: var(--color-zest-100);
            border-width: 0 45px 45px 0;
            transform: translateY(-50%) rotate(-45deg);
        }

        /* main {
        background: var(--color-powderblue-100);
        display: flex;
        flex-direction: column;
    } */
    </style>
</Layout>
