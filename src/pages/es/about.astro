---
import Layout from "../../layouts/Layout.astro"
import ForumEventCard from "../../components/ForumEventCard.astro"
import SectionColumned from "../../components/SectionColumned.astro"
import LocaleSwitcher from "../../components/es/LocaleSwitcher.astro"
---

<Layout>
    <header class="hero">
        <div class="mx-auto max-w-[1024px]">
            <SectionColumned>
                <div>
                    <a href="/es">
                        <img
                            src="/images/pps-logo.svg"
                            alt="Serie de plataformas para profesionales"
                            style="height:96px"
                        />
                    </a>
                </div>
                <div class="p-3 text-right">
                    <LocaleSwitcher />
                </div>
            </SectionColumned>
        </div>
    </header>
    <main class="mx-auto max-w-[1024px]">
        <SectionColumned>
            <div class="pp-prose pl-3">
                <h1 class="">Sobre nosotros</h1>
                <div class="mt-0 text-xl">
                    <em
                        >Apoyando a los profesionales. Fortaleciendo la
                        recuperación.</em
                    >
                </div>
                <p class="mt-4">
                    La Plataforma de Profesionales reúne a fideicomisarios de
                    Clase A de Alcohólicos Anónimos junto con líderes de
                    diversos sectores que apoyan a personas con trastorno por
                    consumo de alcohol (TCA). Crea un espacio para informar y
                    explorar, fortaleciendo y promoviendo enfoques eficaces para
                    la identificación y el apoyo.
                </p>
                <p class="mt-4">
                    Muchos de nosotros somos profesionales o fuimos guiados
                    hacia la recuperación a través de la derivación de
                    profesionales.
                </p>
                <p class="mt-4">
                    Reconocemos el papel fundamental de los profesionales en
                    todos los sistemas y entornos, incluidos:
                </p>
                <ul class="mr-16">
                    <li class="mt-3">
                        <strong>Líderes laborales y organizacionales</strong> — profesionales
                        de recursos humanos, proveedores de programas de asistencia
                        al empleado (PAE) y líderes, directores y gerentes de alto
                        nivel
                    </li>
                    <li class="mt-3">
                        <strong>Atención médica y salud conductual</strong> — proveedores
                        de atención médica, profesionales de la salud mental y trabajadores
                        sociales
                    </li>
                    <li class="mt-3">
                        <strong>Seguridad pública y primera respuesta</strong> — bomberos,
                        policías y otros profesionales de primera línea
                    </li>
                    <li class="mt-3">
                        <strong>Sistemas jurídicos y de justicia</strong> — profesionales
                        del derecho, la justicia, los servicios penitenciarios, la
                        libertad condicional y la reinserción social
                    </li>
                    <li class="mt-3">
                        <strong>Instituciones educativas y comunitarias</strong> —
                        administradores universitarios y de educación superior, facultad,
                        servicios de apoyo estudiantil y líderes de organizaciones
                        sin ánimo de lucro y comunitarias
                    </li>
                </ul>
                <p class="mt-4">
                    Esta plataforma proporciona un foro para aprender, escuchar
                    y compartir enfoques prácticos que apoyen a los
                    profesionales que trabajan en primera línea en el ámbito de
                    la recuperación.
                </p>
                <p class="mt-4 mr-2">
                    <a href="/es">Volver a la página principal</a>
                </p>
            </div>
            <div class="flex flex-col rounded-2xl bg-gray-100 px-4 pt-4">
                <h3 class="text-lg font-bold">Enlaces de AA</h3>
                <p>
                    <a
                        href="https://www.aa.org/es/Cooperation-with-the-Professional-Community"
                        target="_blank"
                        class="text-cyan-700"
                        >Cooperación con la Comunidad Profesional (CCP)
                    </a>
                </p>
                <p class="mt-4">
                    <a
                        href="https://www.aa.org/es/public-information-committees"
                        target="_blank"
                        class="text-cyan-700">Comités de Información Pública</a
                    >
                </p>
            </div>
        </SectionColumned>
    </main>

    <style>
        .hero {
            background:
                linear-gradient(
                    92deg,
                    #b9dfe9 30%,
                    rgba(153, 211, 224, 0.75) 60%,
                    rgba(8, 81, 113, 0.3) 94.45%
                ),
                url("/images/mono-chairs-1600.jpg") lightgray 50% / cover
                    no-repeat;
        }

        /* main {
        background: var(--color-powderblue-100);
        display: flex;
        flex-direction: column;
    } */
    </style>
</Layout>
